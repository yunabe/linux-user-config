pygrep() {
  python -c "import re;import sys;import os;lines = map(lambda l: l.rstrip('\r\n'), sys.stdin.readlines());lines = filter(lambda s:"$1",lines); lines and sys.stdout.write('\n'.join(lines) + '\n')"
}

