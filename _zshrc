append_envvar() {
  local var_name="$1"
  local entry="$2"
  local sep="${3:-:}"
  local value="${(P)var_name}"
  # Initialize the variable when it is currently empty.
  if [ -z "$value" ] ; then
    typeset -gx "$var_name=$entry"
    return
  fi
  # Skip if the entry already exists (checked with separator boundaries).
  if [[ "$sep$value$sep" == *"$sep$entry$sep"* ]]; then
    return
  fi
  typeset -gx "$var_name=$value$sep$entry"
}

prepend_envvar() {
  local var_name="$1"
  local entry="$2"
  local sep="${3:-:}"
  local value="${(P)var_name}"
  # Initialize the variable when it is currently empty.
  if [ -z "$value" ] ; then
    typeset -gx "$var_name=$entry"
    return
  fi
  # Skip if the entry already exists (checked with separator boundaries).
  if [[ "$sep$value$sep" == *"$sep$entry$sep"* ]]; then
    return
  fi
  typeset -gx "$var_name=$entry$sep$value"
}

# PATH helper rule:
# - prepend_path: higher priority (searched earlier). Use when command precedence must change.
# - append_path: lower priority (searched later). Use for optional/fallback tool locations.
append_path() {
  if [ -e "$1" ] ; then
    append_envvar PATH "$1"
  fi
}

prepend_path() {
  if [ -e "$1" ] ; then
    prepend_envvar PATH "$1"
  fi
}

# Keep manual PATH edits in one place for easy review.
# - prepend_path: higher priority
# - append_path: lower priority
prepend_path $HOME/local/bin
prepend_path $HOME/.local/bin
prepend_path $HOME/.cask/bin

append_path $HOME/local/depot_tools
# RubyGems user bin for any installed Ruby version.
# (NnOn): N=no match -> skip, n=numeric sort, On=reverse name sort => newer versions first.
for ruby_gem_bin in "$HOME"/.gem/ruby/*/bin(NnOn); do
  append_path "$ruby_gem_bin"
done
append_path $HOME/local/google-cloud-sdk/bin
# Maven installs are versioned under ~/local (e.g., apache-maven-3.x.y).
# (NnOn): N=no match -> skip, n=numeric sort, On=reverse name sort => newer versions first.
for maven_bin in "$HOME"/local/apache-maven-*/bin(NnOn); do
  append_path "$maven_bin"
done
append_path $HOME/local/go/bin
append_path $HOME/local/gocode/bin
append_path $HOME/.antigravity/antigravity/bin

prepend_path /opt/homebrew/opt/openjdk/bin
prepend_path /usr/lib/go/bin
prepend_path /usr/local/go/bin
prepend_path $HOME/.npm-global/bin

# Enable compsys completion.
autoload -U compinit
compinit

setopt auto_pushd # Make cd push the old directory onto the directory stack.
setopt auto_cd # directory names without commands are evaluated as cd <directory name>.
setopt correct # spell correction
setopt nobeep # no beep

# History 
HISTFILE=$HOME/.zsh.d/.zsh-history # If HISTFILE is empty, zsh save no history :(
SAVEHIST=1000000 # The number of histories on file
HISTSIZE=1000000 # The number of histories that I can search for.
setopt share_history # share history among screens.
setopt extended_history # Timestamps are saved in the history list. We can check timestamps by 'history -i'
                        # If share_history is on, history save timestamps temporarily.
                        # But, without extended_history, those temporary timestamps are deleted when zsh shut down.
setopt hist_no_store # history (fc -l) command is excluded from history.
setopt hist_ignore_dups # if a command is the same previous command, it will not be saved.
setopt hist_ignore_all_dups # remove older duplicate entries when adding a new command.
setopt hist_save_no_dups # omit older duplicates when writing $HISTFILE.
setopt hist_fcntl_lock # use fcntl-based locking for safer concurrent history writes.
setopt hist_ignore_space # Remove command lines from the history list when the first character on the line is a space.
setopt hist_reduce_blanks # Whitespaces in command lines are removed from the history.

setopt numeric_glob_sort # echo * show 1.txt 2.txt 10.txt (not 1.txt 10.txt 2.txt)
setopt extendedglob # 1. Make ^ available outside of [].
                    #    e.g.) echo ^*.c # Show files other than *.c
                    # 2. Make pattern1~pattern2 available.
                    #    e.g.) echo *.c~hello.c # Show c files other than hello.c

bindkey -e # make sure zsh is in emacs mode altough emacs mode is default.

setopt mark_dirs # Append a trailing / to all directory names resulting from filename generation (globbing)
                 # e.g.) echo /hom* -> /home/
setopt list_packed # Try to reduce rows of completion lists (with wider columns).
# Enable filename expansion in args like --prefix=~/path after command names.
setopt magic_equal_subst

# Make completion lists colorful
