[user]
	name = Yu Watanabe
	email = yunabe.public@gmail.com
[color]
	ui = auto
[push]
	default = simple
[merge]
	conflictstyle = diff3

# https://git-scm.com/book/en/v2/Git-Basics-Git-Aliases
[alias]
	br = branch -vv
	co = checkout
	ci = commit
	st = status

# Added by `git lfs install --global`.
# This config enables automatic pointer<->content conversion for files tracked by Git LFS.
[filter "lfs"]
	clean = git-lfs clean -- %f
	smudge = git-lfs smudge -- %f
	process = git-lfs filter-process
	required = true
